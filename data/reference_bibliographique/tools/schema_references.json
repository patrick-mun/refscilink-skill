{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RefSciLink references.json",
  "type": "object",
  "required": [
    "metadata",
    "references"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "generated_by",
        "module_version",
        "schema_version",
        "generated_at",
        "updated_at",
        "language",
        "source_markdown",
        "source_markdown_sha256",
        "enrichment_mode",
        "reference_count"
      ],
      "properties": {
        "generated_by": { "type": "string" },
        "module_version": { "type": "string" },
        "version": { "type": "string" },
        "schema_version": { "type": "string" },
        "generated_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "language": { "type": "string" },
        "source_markdown": { "type": "string" },
        "source_markdown_sha256": { "type": "string" },
        "enrichment_mode": { "type": "string" },
        "reference_count": { "type": "number" }
      },
      "additionalProperties": true
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "number",
          "raw_reference",
          "title",
          "authors",
          "access_type",
          "validation_status",
          "extraction_status",
          "metadata_status"
        ],
        "properties": {
          "id": { "type": "string" },
          "number": { "type": "number" },
          "raw_reference": { "type": "string" },
          "title": { "type": "string" },
          "authors": { "type": "array", "items": { "type": "string" } },
          "year": { "type": "string" },
          "journal": { "type": "string" },
          "publisher": { "type": "string" },
          "volume": { "type": "string" },
          "issue": { "type": "string" },
          "pages": { "type": "string" },
          "doi": { "type": "string" },
          "pmid": { "type": "string" },
          "pmcid": { "type": "string" },
          "url": { "type": "string" },
          "pdf_url": { "type": "string" },
          "source_url": { "type": "string" },
          "access_type": {
            "enum": [
              "open_access",
              "abstract_only",
              "accepted_author_version",
              "preprint",
              "paywalled",
              "unknown"
            ]
          },
          "theme": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "short_summary": { "type": "string" },
          "detailed_summary": { "type": "string" },
          "key_points": { "type": "array", "items": { "type": "string" } },
          "project_relevance": { "type": "string" },
          "limitations": { "type": "string" },
          "validated": { "type": "boolean" },
          "validation_status": {
            "enum": [
              "pending_validation",
              "validated",
              "rejected",
              "needs_revision"
            ]
          },
          "validated_by": { "type": "string" },
          "validation_date": { "type": "string" },
          "extraction_status": {
            "enum": [
              "extracted",
              "partially_extracted",
              "incomplete",
              "duplicate_suspected",
              "manual_review_required"
            ]
          },
          "metadata_status": {
            "enum": [
              "not_enriched",
              "metadata_found",
              "metadata_partial",
              "metadata_not_found",
              "metadata_to_verify",
              "enrichment_failed"
            ]
          },
          "review_notes": { "type": "string" },
          "source_markdown": { "type": "string" },
          "source_location": {
            "type": "object",
            "required": [
              "line_start",
              "line_end",
              "section_title",
              "section_level"
            ],
            "properties": {
              "line_start": { "type": "number" },
              "line_end": { "type": "number" },
              "section_title": { "type": "string" },
              "section_level": { "type": "number" }
            },
            "additionalProperties": false
          },
          "duplicate_of": { "type": "string" },
          "duplicate_confidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
